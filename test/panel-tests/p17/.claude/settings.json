{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-changes.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/on-edit-lint.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-secrets.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}